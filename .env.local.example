NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
MAGUROMARU_ENABLE_MOCK_ADMIN=false
MAGUROMARU_ENABLE_PRODUCTION_MOCK=false

# 任意: 分散レート制限（Upstash Redis）。未設定時はサーバー内メモリのみ。
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 任意: スナップショット再取得の最小間隔（ms）。既定 45000。
# NEXT_PUBLIC_APP_SNAPSHOT_STALE_MS=45000

# まぐろ丸Bot（Vercel Cron /api/cron/store-ai-blurb）
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# CRON_SECRET=（Vercel の Cron と同じ Bearer）
